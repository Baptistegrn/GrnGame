class Primitive {
    foreign static pixel(x, y, c_idx, a)

    foreign static line(x1, y1, x2, y2, c_idx, a)

    foreign static rect(x, y, w, h, c_idx, a)

    foreign static rect_fill(x, y, w, h, c_idx, a)

    foreign static circle(x, y, radius, c_idx, a)

    foreign static circle_fill(x, y, radius, c_idx, a)
}
